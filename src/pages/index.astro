---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const scopeItems = [
  {
    title: "软件开发",
    description: "围绕实际使用场景，推进工具类产品的设计与开发。",
    icon: "uil:setting",
  },
  {
    title: "Web 网站",
    description: "面向浏览器访问的静态页面、网站与相关前端功能开发。",
    icon: "uil:window",
  },
  {
    title: "App 与微信小程序",
    description: "结合移动端与微信生态，开发轻量、实用的应用体验。",
    icon: "uil:mobile-android",
  },
];

const products = [
  {
    name: "手持全屏弹幕",
    type: "微信小程序",
    description:
      "核心功能为全屏弹幕和手机滚动字幕。用户输入文字后，可在手机横屏状态下全屏展示大字弹幕、滚动字幕等效果，适用于接人提示、活动提示、聚会互动等场景。",
    icon: "uil:megaphone",
  },
  {
    name: "证件水印",
    type: "微信小程序",
    description:
      "用于为身份证、房产证等证件图片添加水印，帮助用户在提交或使用证件资料时增加用途标识，降低证件被挪用的风险。",
    icon: "uil:shield-check",
  },
];
---

<Layout>
  <Container>
    <main>
      <section
        id="studio"
        class="relative overflow-hidden rounded-sm bg-slate-950 px-6 py-18 text-white md:px-12 md:py-24">
        <div
          class="absolute inset-x-0 top-0 h-1 bg-[linear-gradient(90deg,#38bdf8,#f59e0b,#22c55e)]">
        </div>
        <div class="absolute inset-0 opacity-20" aria-hidden="true">
          <div
            class="absolute right-8 top-10 hidden w-80 border border-white/20 p-4 text-sm text-white/70 md:block">
            <div class="mb-4 flex gap-2">
              <span class="h-2 w-2 rounded-full bg-sky-300"></span>
              <span class="h-2 w-2 rounded-full bg-amber-300"></span>
              <span class="h-2 w-2 rounded-full bg-emerald-300"></span>
            </div>
            <div class="space-y-3">
              <div class="h-2 w-4/5 bg-white/50"></div>
              <div class="h-2 w-2/3 bg-white/30"></div>
              <div class="h-2 w-5/6 bg-white/40"></div>
            </div>
          </div>
          <div
            class="absolute bottom-12 right-24 hidden border border-white/20 px-5 py-4 text-sm text-white/70 lg:block">
            Web / App / 小程序 / 工具产品
          </div>
        </div>

        <div class="relative max-w-3xl">
          <p class="text-sm font-medium text-sky-200">
            云南省大理州鹤庆县
          </p>
          <h1 class="mt-5 text-4xl font-bold leading-tight md:text-6xl">
            鹤庆县砺行信息工作室（个体工商户）
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-200">
            主要从事软件开发、Web 网站、App 与微信小程序相关开发。工作室拥有丰富的互联网行业经验，目前专注工具类产品开发。
          </p>
        </div>
      </section>

      <section id="scope" class="py-16 md:py-20">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-sky-700">业务方向</p>
          <h2 class="mt-3 text-3xl font-bold text-slate-950 md:text-4xl">
            聚焦软件与轻量化互联网产品
          </h2>
          <p class="mt-4 text-lg leading-8 text-slate-600">
            业务内容保持清晰直接，围绕软件开发、网站、App 和微信小程序展开，当前重点投入工具类产品。
          </p>
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {
            scopeItems.map((item) => (
              <div class="border border-slate-200 bg-white p-6">
                <div class="flex h-10 w-10 items-center justify-center bg-slate-950 text-white">
                  <Icon name={item.icon} class="h-5 w-5" />
                </div>
                <h3 class="mt-5 text-xl font-semibold text-slate-950">
                  {item.title}
                </h3>
                <p class="mt-3 leading-7 text-slate-600">
                  {item.description}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <section id="products" class="border-y border-slate-200 py-16 md:py-20">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold text-sky-700">产品介绍</p>
            <h2 class="mt-3 text-3xl font-bold text-slate-950 md:text-4xl">
              当前展示的工具类产品
            </h2>
          </div>
          <p class="max-w-md text-base leading-7 text-slate-600">
            页面仅列出当前需要展示的两款微信小程序产品。
          </p>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {
            products.map((product) => (
              <article class="border border-slate-200 bg-white p-6 md:p-8">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-sm font-medium text-slate-500">
                      {product.type}
                    </p>
                    <h3 class="mt-2 text-2xl font-semibold text-slate-950">
                      {product.name}
                    </h3>
                  </div>
                  <div class="flex h-11 w-11 shrink-0 items-center justify-center bg-sky-50 text-sky-700">
                    <Icon name={product.icon} class="h-6 w-6" />
                  </div>
                </div>
                <p class="mt-5 leading-8 text-slate-600">
                  {product.description}
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="address" class="py-16 md:py-20">
        <div class="grid gap-8 md:grid-cols-[1fr_1.4fr] md:items-start">
          <div>
            <p class="text-sm font-semibold text-sky-700">地址</p>
            <h2 class="mt-3 text-3xl font-bold text-slate-950 md:text-4xl">
              鹤庆县本地信息工作室
            </h2>
          </div>
          <div class="border-l-4 border-amber-400 pl-6">
            <p class="text-xl font-semibold text-slate-950">
              云南省大理州鹤庆县
            </p>
            <p class="mt-4 leading-8 text-slate-600">
              工作室以互联网行业经验为基础，持续围绕实用工具产品进行开发与打磨。
            </p>
          </div>
        </div>
      </section>
    </main>
  </Container>
</Layout>
